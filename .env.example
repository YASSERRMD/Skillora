# Skillora Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ────────────────────────────────────────────────
# Database
# ────────────────────────────────────────────────
DATABASE_URL=postgres://skillora:skillora_secret@localhost:5432/skillora?sslmode=disable
POSTGRES_DB=skillora
POSTGRES_USER=skillora
POSTGRES_PASSWORD=skillora_secret

# ────────────────────────────────────────────────
# Cache
# ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ────────────────────────────────────────────────
# Google OAuth2
# ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ────────────────────────────────────────────────
# Auth
# ────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# AES-256 master key for encrypting LLM API keys stored in DB.
# Must be exactly 32 bytes (64 hex characters).
# Generate with: openssl rand -hex 32
AES_MASTER_KEY=your_64_char_hex_key_here
